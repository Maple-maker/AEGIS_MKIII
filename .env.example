# ── AEGIS Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# On Railway: set these in the Variables tab of your project.

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# OpenAI — voice transcription (Whisper) + TTS + AI responses
OPENAI_API_KEY=sk-...

# Anthropic — Claude AI for responses and vault context
ANTHROPIC_API_KEY=sk-ant-...

# ── OPTIONAL: MARKET DATA ────────────────────────────────────────────────────

# Coinbase API (read-only) — live BTC portfolio tracking
# Create at: https://www.coinbase.com/settings/api
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ── OPTIONAL: MESSAGING ──────────────────────────────────────────────────────

# Telegram bot — receive voice memos + messages on your phone
# Create via @BotFather on Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── OPTIONAL: INTEGRATIONS ───────────────────────────────────────────────────

# Obsidian vault path (local mode only — not available on cloud deploy)
VAULT_PATH=/Users/you/Documents/your-vault

# ElevenLabs — premium JARVIS-style voice (replaces OpenAI TTS when set)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── OPTIONAL: AUTH ───────────────────────────────────────────────────────────

# Secret key for Flask sessions — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# ── RAILWAY SPECIFIC ─────────────────────────────────────────────────────────
# PORT is set automatically by Railway — do not set manually
# PORT=8080
